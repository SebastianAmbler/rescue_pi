[Unit]
Description=IMX708 camera_ros + MJPEG bridge (ROS topics + browser stream)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
Group=video
SupplementaryGroups=render
WorkingDirectory=/home/pi/ros2_ws
# ROS_DOMAIN_ID unset -> default 0, matching the rest of the robot's nodes.
ExecStart=/bin/bash /home/pi/ros2_ws/run_camera_stack.sh
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
